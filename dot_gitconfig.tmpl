# This is Git's per-user configuration file.
[include]
path = {{ .chezmoi.homeDir }}/.config/delta-themes.gitconfig

[user]
name = Alex Schreifels
email = {{ .email }}

[core]
pager = delta

[interactive]
diffFilter = delta --color-only

[delta]
features = catppuccin-macchiato-full

[merge]
conflictStyle = zdiff3

[diff]
colorMoved = default

[rerere]
enabled = true

[column]
ui = auto

[branch]
sort = -committerdate
