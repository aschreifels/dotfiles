{
  "$schema": "https://charm.land/crush.json",
  "options": {
    "skills_paths": [
      "~/.config/crush/skills"
    ],
    "context_paths": [
      "~/.config/ai/CONVENTIONS.md",
      "~/.config/ai/CONVENTION-TRACKING.md",
      "~/.config/crush/skills/cmux-notifications/SKILL.md",
      "~/.config/crush/skills/cwt-orchestrator/SKILL.md"
    ]
  },
  "mcp": {
    "switchboard": {
      "type": "http",
      "url": "http://localhost:3847/mcp",
      "timeout": 120
    }
  },
    "permissions": {
    "allowed_tools": [
      "cmux*",
      "mcp_switchboard_search",
      "mcp_switchboard_execute",
      "linear*",
      "mcp*",
      "bash(git *)",
      "bash(grep *)",
      "view",
      "edit",
      "multiedit",
      "write",
      "bash",
      "grep",
      "glob",
      "ls",
      "agent",
      "fetch",
      "agentic_fetch",
      "download",
      "sourcegraph",
      "todos",
      "lsp_diagnostics",
      "lsp_references"
    ]
  },
  "lsp": {
    "go": {
      "command": "gopls",
      "env": {
        "GOTOOLCHAIN": "go1.25.5"
      }
    },
    "typescript": {
      "command": "vstls",
      "args": [
        "--stdio"
      ]
    },
    "yaml": {
      "command": "yaml-language-server",
      "args": [
        "--stdio"
      ]
    },
    "json": {
      "command": "vscode-json-language-server",
      "args": [
        "--stdio"
      ]
    }
  }
}
